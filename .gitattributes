# Auto-detección por defecto, normalizar EOL en checkin
* text=auto

# Scripts Windows: forzar CRLF para evitar problemas con Windows PowerShell
*.ps1   text eol=crlf
*.vbs   text eol=crlf
*.cmd   text eol=crlf
*.bat   text eol=crlf

# Source code: LF
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf

# Binarios
*.bin   binary
*.gguf  binary
*.exe   binary
*.dll   binary
*.png   binary
*.jpg   binary
*.wav   binary
